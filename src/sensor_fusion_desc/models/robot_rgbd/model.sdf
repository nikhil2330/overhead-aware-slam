<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="robot_rgbd">
    <static>false</static>

    <link name="chassis">
      <pose>0 0 0.375 0 0 0</pose>

      <inertial>
        <pose>0 0 -0.30 0 0 0</pose>
        <mass>60.0</mass>
        <inertia>
          <ixx>3.0</ixx>
          <iyy>3.0</iyy>
          <izz>2.0</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="base_collision">
        <pose>0 0 -0.20 0 0 0</pose>
        <geometry>
          <box>
            <size>0.30 0.30 0.18</size>
          </box>
        </geometry>
        <surface>
          <contact>
            <collide_bitmask>0x01</collide_bitmask>
          </contact>
        </surface>
      </collision>

      <collision name="full_robot_collision">
        <pose>0 0 0.10 0 0 0</pose>
        <geometry>
          <box>
            <size>0.30 0.30 0.65</size>
          </box>
        </geometry>
        <surface>
          <contact>
            <collide_bitmask>0x01</collide_bitmask>
          </contact>
        </surface>
      </collision>

      <visual name="base_block_visual">
        <pose>0 0 -0.20 0 0 0</pose>
        <geometry>
          <box>
            <size>0.30 0.30 0.15</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.9 1</ambient>
          <diffuse>0.1 0.1 0.9 1</diffuse>
        </material>
      </visual>

      <visual name="top_plate_visual">
        <pose>0 0 0.365 0 0 0</pose>
        <geometry>
          <box>
            <size>0.30 0.30 0.02</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.9 1</ambient>
          <diffuse>0.1 0.1 0.9 1</diffuse>
        </material>
      </visual>

      <visual name="pillar_fl">
        <pose> 0.145  0.145 0.115 0 0 0</pose>
        <geometry><box><size>0.01 0.01 0.48</size></box></geometry>
        <material><ambient>0.1 0.1 0.9 1</ambient><diffuse>0.1 0.1 0.9 1</diffuse></material>
      </visual>
      <visual name="pillar_fr">
        <pose> 0.145 -0.145 0.115 0 0 0</pose>
        <geometry><box><size>0.01 0.01 0.48</size></box></geometry>
        <material><ambient>0.1 0.1 0.9 1</ambient><diffuse>0.1 0.1 0.9 1</diffuse></material>
      </visual>
      <visual name="pillar_rl">
        <pose>-0.145  0.145 0.115 0 0 0</pose>
        <geometry><box><size>0.01 0.01 0.48</size></box></geometry>
        <material><ambient>0.1 0.1 0.9 1</ambient><diffuse>0.1 0.1 0.9 1</diffuse></material>
      </visual>
      <visual name="pillar_rr">
        <pose>-0.145 -0.145 0.115 0 0 0</pose>
        <geometry><box><size>0.01 0.01 0.48</size></box></geometry>
        <material><ambient>0.1 0.1 0.9 1</ambient><diffuse>0.1 0.1 0.9 1</diffuse></material>
      </visual>

      <visual name="front_caster_mount_visual">
        <pose>0.135 0 -0.31 0 0 0</pose>
        <geometry>
          <box>
            <size>0.03 0.06 0.09</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.9 1</ambient>
          <diffuse>0.1 0.1 0.9 1</diffuse>
        </material>
      </visual>

      <visual name="rear_caster_mount_visual">
        <pose>-0.135 0 -0.31 0 0 0</pose>
        <geometry>
          <box>
            <size>0.03 0.06 0.09</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.9 1</ambient>
          <diffuse>0.1 0.1 0.9 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="lidar_link">
      <pose relative_to="chassis">0 0 -0.125 0 0 0</pose>

      <visual name="lidar_visual">
        <pose>0 0 0.02 0 0 0</pose>
        <geometry><cylinder><radius>0.03</radius><length>0.03</length></cylinder></geometry>
        <material>
          <ambient>0.25 0.25 0.25 1</ambient>
          <diffuse>0.25 0.25 0.25 1</diffuse>
        </material>
      </visual>

      <sensor name="lidar" type="gpu_lidar">
        <always_on>true</always_on>
        <visualize>true</visualize>
        <update_rate>10</update_rate>
        <topic>/scan</topic>

        <ray>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle> 3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.25</min>
            <max>8.0</max>
            <resolution>0.01</resolution>
          </range>
        </ray>
      </sensor>
    </link>

    <joint name="lidar_joint" type="fixed">
      <parent>chassis</parent>
      <child>lidar_link</child>
    </joint>

    <link name="camera_link">
      <pose relative_to="chassis">0 0 0.70 0 0.28 0</pose>
      <visual name="camera_visual">
        <geometry>
          <box><size>0.03 0.03 0.03</size></box>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>

      <sensor name="rgbd_cam" type="rgbd_camera">
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <visualize>true</visualize>
        <topic>/camera</topic>

        <camera name="rgbd_camera">
          <camera_info_topic>/camera/camera_info</camera_info_topic>
          <optical_frame_id>camera_link</optical_frame_id>
          <horizontal_fov>1.5</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.05</near>
            <far>20.0</far>
          </clip>
          <depth_camera>
            <clip>
              <near>0.05</near>
              <far>20.0</far>
            </clip>
          </depth_camera>
        </camera>
      </sensor>
    </link>

    <joint name="camera_joint" type="fixed">
      <parent>chassis</parent>
      <child>camera_link</child>
    </joint>

    <link name="left_wheel">
      <pose relative_to="chassis">0.0 0.13 -0.325 0 0 0</pose>

      <collision name="collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.05</radius><length>0.03</length></cylinder></geometry>
        <surface>
          <contact>
            <collide_bitmask>0x02</collide_bitmask>
            <ode>
              <kp>80000</kp>
              <kd>5</kd>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>1.4</mu>
              <mu2>1.4</mu2>
              <slip1>0.0</slip1>
              <slip2>0.0</slip2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.05</radius><length>0.03</length></cylinder></geometry>
        <material><ambient>0.02 0.02 0.02 1</ambient><diffuse>0.02 0.02 0.02 1</diffuse></material>
      </visual>

      <inertial>
        <mass>0.3</mass>
        <inertia>
          <ixx>0.00021</ixx>
          <iyy>0.000375</iyy>
          <izz>0.00021</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <pose relative_to="chassis">0.0 0.13 -0.325 0 0 0</pose>
      <parent>chassis</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <dynamics>
          <damping>6.0</damping>
          <friction>2.0</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="right_wheel">
      <pose relative_to="chassis">0.0 -0.13 -0.325 0 0 0</pose>

      <collision name="collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.05</radius><length>0.03</length></cylinder></geometry>
        <surface>
          <contact>
            <collide_bitmask>0x02</collide_bitmask>
            <ode>
              <kp>80000</kp>
              <kd>5</kd>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>1.4</mu>
              <mu2>1.4</mu2>
              <slip1>0.0</slip1>
              <slip2>0.0</slip2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.05</radius><length>0.03</length></cylinder></geometry>
        <material><ambient>0.02 0.02 0.02 1</ambient><diffuse>0.02 0.02 0.02 1</diffuse></material>
      </visual>

      <inertial>
        <mass>0.3</mass>
        <inertia>
          <ixx>0.00021</ixx>
          <iyy>0.000375</iyy>
          <izz>0.00021</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
    </link>

    <joint name="right_wheel_joint" type="revolute">
      <pose relative_to="chassis">0.0 -0.13 -0.325 0 0 0</pose>
      <parent>chassis</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <dynamics>
          <damping>6.0</damping>
          <friction>2.0</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="front_caster">
      <pose relative_to="chassis">0.135 0 -0.345 0 0 0</pose>

      <collision name="collision">
        <geometry><sphere><radius>0.03</radius></sphere></geometry>
        <surface>
          <contact>
            <collide_bitmask>0x02</collide_bitmask>
            <ode>
              <kp>60000</kp>
              <kd>5</kd>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>0.05</mu>
              <mu2>0.05</mu2>
              <slip1>1.0</slip1>
              <slip2>1.0</slip2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="visual">
        <geometry><sphere><radius>0.03</radius></sphere></geometry>
        <material><ambient>0.4 0.4 0.4 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material>
      </visual>

      <inertial>
        <mass>0.25</mass>
        <inertia>
          <ixx>0.00009</ixx>
          <iyy>0.00009</iyy>
          <izz>0.00009</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
    </link>

    <joint name="front_caster_joint" type="fixed">
      <pose relative_to="chassis">0.135 0 -0.345 0 0 0</pose>
      <parent>chassis</parent>
      <child>front_caster</child>
    </joint>

    <link name="rear_caster">
      <pose relative_to="chassis">-0.135 0 -0.345 0 0 0</pose>

      <collision name="collision">
        <geometry><sphere><radius>0.03</radius></sphere></geometry>
        <surface>
          <contact>
            <collide_bitmask>0x02</collide_bitmask>
            <ode>
              <kp>60000</kp>
              <kd>5</kd>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>0.05</mu>
              <mu2>0.05</mu2>
              <slip1>1.0</slip1>
              <slip2>1.0</slip2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="visual">
        <geometry><sphere><radius>0.03</radius></sphere></geometry>
        <material><ambient>0.4 0.4 0.4 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material>
      </visual>

      <inertial>
        <mass>0.25</mass>
        <inertia>
          <ixx>0.00009</ixx>
          <iyy>0.00009</iyy>
          <izz>0.00009</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
    </link>

    <joint name="rear_caster_joint" type="fixed">
      <pose relative_to="chassis">-0.135 0 -0.345 0 0 0</pose>
      <parent>chassis</parent>
      <child>rear_caster</child>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <wheel_separation>0.26</wheel_separation>
      <wheel_radius>0.05</wheel_radius>

      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>

    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors"/>

    <plugin
        filename="gz-sim-pose-publisher-system"
        name="gz::sim::systems::PosePublisher">
      <publish_model_pose>true</publish_model_pose>
      <publish_link_pose>false</publish_link_pose>
      <publish_collision_pose>false</publish_collision_pose>
      <publish_visual_pose>false</publish_visual_pose>
      <publish_nested_model_pose>true</publish_nested_model_pose>
      <update_frequency>50</update_frequency>
    </plugin>
  </model>
</sdf>
